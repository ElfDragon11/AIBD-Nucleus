# Copy to .env or .env.local (Vite reads both).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Use one or the other (Dashboard → Publishable matches sb_publishable_…; anon is legacy "anon public"):
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# VITE_SUPABASE_ANON_KEY=your_legacy_anon_jwt_if_needed

# OpenAI: `supabase secrets set OPENAI_API_KEY` (optional `OPENAI_MODEL`) — used by
# classify-lead, process-intake-answer, find-matches, map-csv-columns, process-csv-import.
# Edge Functions also need `SUPABASE_URL`, `SUPABASE_ANON_KEY`, and `SUPABASE_SERVICE_ROLE_KEY`
# in the Supabase project (Dashboard → Edge Functions secrets) for admin CSV helpers that validate JWTs.
# Optional: run `deno run -A supabase/scripts/backfill-embeddings.ts` locally for embeddings backfill.

#
# Intro emails (Edge `send-intro-email`): set secrets on the project, not in Vite:
#   supabase secrets set RESEND_API_KEY=re_...
#   supabase secrets set RESEND_FROM="Nucleus Concierge <onboarding@resend.dev>"
