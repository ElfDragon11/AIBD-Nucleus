# Copy to .env or .env.local (Vite reads both).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Use one or the other (Dashboard → Publishable matches sb_publishable_…; anon is legacy "anon public"):
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# VITE_SUPABASE_ANON_KEY=your_legacy_anon_jwt_if_needed

# Phase 4 AI intake: set OPENAI_API_KEY (optional OPENAI_MODEL) with
# `supabase secrets set` on the project—for Edge Functions, not Vite.
